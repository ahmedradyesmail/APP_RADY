APP_NAME=Auth Backend
# Primary database URL (recommended: PostgreSQL for all app data).
# Railway: set this from your Postgres service DATABASE_URL.
DATABASE_URL=
# Optional local fallback if DATABASE_URL is empty.
SQLITE_DB_URL=sqlite:///./app.db
# Migration note: first run on fresh Postgres starts with empty users table.
# The app will bootstrap admin again from ADMIN_USERNAME and ADMIN_PASSWORD.
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# HttpOnly cookies for browser sessions (names: tfg_access / tfg_refresh). On HTTPS set AUTH_COOKIE_SECURE=true.
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=lax

# ─────────────────────────────────────────
# VARIABLE: JWT_SECRET_KEY
# What it does: Signs and verifies all JWT tokens
# For Railway (current): Must be a random string, minimum 64 characters
# For production server: Generate a new one using: openssl rand -hex 64
# For Android APK: No change needed — same backend, same secret
# ─────────────────────────────────────────
JWT_SECRET_KEY=your-secret-here

# ─────────────────────────────────────────
# VARIABLE: ADMIN_USERNAME
# What it does: Username for the bootstrap admin account
# For Railway (current): Use a non-guessable admin username
# For production server: Keep unique and private (not "admin")
# For Android APK: No change needed — managed on backend only
# ─────────────────────────────────────────
ADMIN_USERNAME=your-admin-username-here

# ─────────────────────────────────────────
# VARIABLE: ADMIN_PASSWORD
# What it does: Password for the bootstrap admin account
# For Railway (current): Use a strong password (16+ chars)
# For production server: Rotate regularly and store securely
# For Android APK: No change needed — managed on backend only
# ─────────────────────────────────────────
ADMIN_PASSWORD=your-admin-password-here

# ─────────────────────────────────────────
# VARIABLE: ALLOWED_ORIGINS
# What it does: Controls which domains can call the API from a browser
# For Railway (current): Use only your Railway domain
# For production server: Add your real domain alongside Railway if needed
# For Android APK: Native HTTP clients ignore CORS entirely — no change needed here
#                  but keep the Railway domain in the list for the web version
# ─────────────────────────────────────────
ALLOWED_ORIGINS=https://apprady-production.up.railway.app

# Redis (recommended with multiple Gunicorn/uvicorn workers):
# - Shared job state (transcribe/check polling).
# - Provider API key pools (Gemini, ORS, Google Maps): round-robin, park on 429 until UTC midnight, remove invalid keys.
# Railway: add Redis plugin, then set REDIS_URL (often redis://default:...@...:6379).
# If empty: in-memory jobs only (single worker) and no shared key pools — add keys in Admin only after REDIS_URL is set.
REDIS_URL=

# If you run Gunicorn/Uvicorn with more than one HTTP worker, REDIS_URL becomes mandatory at startup (WS tickets + shared state).
# Gunicorn may not export worker count to the app — set explicitly when needed, e.g. APP_WORKER_COUNT=4
# APP_WORKER_COUNT=1

# One-time ticket TTL for WebSocket /ws/check-live (seconds, server clamps 15–300). Shared across workers when REDIS_URL is set.
# WS_CHECK_LIVE_TICKET_TTL_SECONDS=90

# Concurrent Gemini Live sessions per process.
GEMINI_LIVE_MAX_CONCURRENT=150

# Check queue tuning.
CHECK_QUEUE_WORKERS=2
CHECK_QUEUE_MAX_DEPTH=200
CHECK_USER_RATE_LIMIT_PER_MINUTE=3

# Optional: Postgres for check/فرز storage.
# Option A (recommended on Railway): set CHECK_POSTGRES_URL directly from your Postgres service variable.
# Example: postgresql://check_app:secret@localhost:5432/checkdb
CHECK_POSTGRES_URL=
# Option B (split variables): used only if CHECK_POSTGRES_URL is empty.
CHECK_POSTGRES_HOST=
CHECK_POSTGRES_PORT=5432
CHECK_POSTGRES_DBNAME=
CHECK_POSTGRES_USER=
CHECK_POSTGRES_PASSWORD=
# If all CHECK_POSTGRES_* are empty, app reuses DATABASE_URL (single-DB mode).

# API keys (Gemini / ORS / Google Maps): add only via Admin → key pools; stored in Redis (not env/file).

# Gemini Live: model IDs — add in Admin → Gemini models (channel live).
# Optional TTS voice name for Live setup (default Kore).
# GEMINI_LIVE_VOICE=Kore
