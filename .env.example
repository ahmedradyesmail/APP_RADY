APP_NAME=Auth Backend
SQLITE_DB_URL=sqlite:///./app.db
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────
# VARIABLE: JWT_SECRET_KEY
# What it does: Signs and verifies all JWT tokens
# For Railway (current): Must be a random string, minimum 64 characters
# For production server: Generate a new one using: openssl rand -hex 64
# For Android APK: No change needed — same backend, same secret
# ─────────────────────────────────────────
JWT_SECRET_KEY=your-secret-here

# ─────────────────────────────────────────
# VARIABLE: ADMIN_USERNAME
# What it does: Username for the bootstrap admin account
# For Railway (current): Use a non-guessable admin username
# For production server: Keep unique and private (not "admin")
# For Android APK: No change needed — managed on backend only
# ─────────────────────────────────────────
ADMIN_USERNAME=your-admin-username-here

# ─────────────────────────────────────────
# VARIABLE: ADMIN_PASSWORD
# What it does: Password for the bootstrap admin account
# For Railway (current): Use a strong password (16+ chars)
# For production server: Rotate regularly and store securely
# For Android APK: No change needed — managed on backend only
# ─────────────────────────────────────────
ADMIN_PASSWORD=your-admin-password-here

# ─────────────────────────────────────────
# VARIABLE: ALLOWED_ORIGINS
# What it does: Controls which domains can call the API from a browser
# For Railway (current): Use only your Railway domain
# For production server: Add your real domain alongside Railway if needed
# For Android APK: Native HTTP clients ignore CORS entirely — no change needed here
#                  but keep the Railway domain in the list for the web version
# ─────────────────────────────────────────
ALLOWED_ORIGINS=https://apprady-production.up.railway.app
